/* my.wxss */
page {
  background-color: #f8fcf9;
  font-family: -apple-system, BlinkMacSystemFont, 'Helvetica Neue', Helvetica, sans-serif;
}

.container {
  padding-bottom: 20rpx;
}

/* 顶部状态栏 */
.status-bar {
  background-color: #4a9c7a;
  padding: 30rpx 30rpx 20rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
  color: white;
  font-size: 24rpx;
  box-sizing: border-box;
  width: 100%;
}

.status-time {
  flex: 1;
  text-align: left;
}

.status-wechat {
  flex: 1;
  text-align: center;
  font-weight: 500;
}

.battery-info {
  flex: 1;
  display: flex;
  justify-content: flex-end;
  align-items: center;
}

.battery-percent {
  margin-right: 10rpx;
}

.battery-icon {
  width: 30rpx;
  height: 16rpx;
  background-color: #fff;
  border-radius: 2rpx;
  position: relative;
}

.battery-icon::after {
  content: '';
  position: absolute;
  right: -4rpx;
  top: 50%;
  transform: translateY(-50%);
  width: 2rpx;
  height: 8rpx;
  background-color: #fff;
}

/* 用户信息区域 */
.user-section {
  background: linear-gradient(to right, #4a9c7a, #6ba889);
  border-radius: 10rpx;
  margin-bottom: 20rpx;
  width: calc(100%);
  position: relative;
  color: white;
  margin-bottom: 20rpx;
  margin-top: 20rpx;
  padding: 0;
  box-sizing: border-box;
  overflow: hidden;
}
.user-header {
  display: flex;
  align-items: center;
  margin-bottom: 30rpx;
}

.user-avatar {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  border: 4rpx solid rgba(255, 255, 255, 0.3);
  margin-right: 30rpx;
}

.user-info {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.user-name {
  font-size: 36rpx;
  font-weight: 700;
  margin-bottom: 10rpx;
}

.user-desc {
  font-size: 24rpx;
  opacity: 0.9;
}

.user-level {
  background-color: rgba(255, 255, 255, 0.2);
  padding: 10rpx 20rpx;
  border-radius: 30rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.level-text {
  font-size: 24rpx;
  font-weight: 600;
  margin-bottom: 4rpx;
}

.level-name {
  font-size: 20rpx;
  opacity: 0.9;
}

.user-stats {
  display: flex;
  justify-content: space-around;
  border-top: 1rpx solid rgba(255, 255, 255, 0.2);
  padding-top: 30rpx;
}

.stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.stat-number {
  font-size: 36rpx;
  font-weight: 700;
  margin-bottom: 8rpx;
}

.stat-label {
  font-size: 24rpx;
  opacity: 0.9;
}

/* 功能列表 */
.function-list {
  height: calc(100vh - 2rpx);
  padding: 0 30rpx;
  width: 100%;
  box-sizing: border-box;
}

.function-section {
  background-color: #ffffff;
  border-radius: 20rpx;
  margin-bottom: 30rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 20rpx rgba(144, 202, 180, 0.1);
}

.section-header {
  padding: 25rpx 30rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.section-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #1a6840;
}

/* 功能网格 */
.function-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  padding: 30rpx 0;
}

.function-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 10rpx 0;
}

.function-icon-wrapper {
  width: 60rpx;
  height: 60rpx;
  background-color: #e8f5ef;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 15rpx;
  transition: all 0.3s;
}

.function-item:active .function-icon-wrapper {
  transform: scale(0.95);
  background-color: #d0e8dc;
}

.function-icon {
  width: 40rpx;
  height: 40rpx;
}

.function-text {
  font-size: 24rpx;
  color: #333;
  text-align: center;
}

/* 服务列表 */
.service-list {
  padding: 0 30rpx;
}

.service-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 30rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.service-item:last-child {
  border-bottom: none;
}

.service-item-left {
  display: flex;
  align-items: center;
}

.service-icon {
  width: 40rpx;
  height: 40rpx;
  margin-right: 20rpx;
}

.service-text {
  font-size: 28rpx;
  color: #333;
}

.service-arrow {
  width: 24rpx;
  height: 24rpx;
  opacity: 0.5;
}

/* 推荐卡片 */
.recommend-card {
  background: linear-gradient(135deg, #4a9c7a 0%, #6ba889 100%);
  border-radius: 20rpx;
  padding: 30rpx;
  margin-bottom: 30rpx;
  color: white;
  box-shadow: 0 4rpx 20rpx rgba(74, 156, 122, 0.3);
}

.recommend-header {
  margin-bottom: 20rpx;
}

.recommend-title {
  font-size: 32rpx;
  font-weight: 700;
  display: block;
  margin-bottom: 8rpx;
}

.recommend-subtitle {
  font-size: 24rpx;
  opacity: 0.9;
}

.recommend-content {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.recommend-desc {
  font-size: 24rpx;
  opacity: 0.9;
  flex: 1;
  margin-right: 20rpx;
  line-height: 1.4;
}

.recommend-btn {
  background-color: white;
  color: #4a9c7a;
  border: none;
  border-radius: 40rpx;
  padding: 12rpx 24rpx;
  font-size: 24rpx;
  font-weight: 600;
  transition: all 0.3s;
}

.recommend-btn:active {
  transform: scale(0.95);
}

/* 版本信息 */
.version-info {
  text-align: center;
  padding: 30rpx 0 30rpx;
  color: #a8c9bb;
}

.version-text {
  font-size: 24rpx;
  display: block;
  margin-bottom: 10rpx;
}

.copyright {
  font-size: 20rpx;
  opacity: 0.7;
}

/* 响应式调整 */
@media (max-width: 480px) {
  .function-grid {
    grid-template-columns: repeat(2, 1fr);
    gap: 20rpx;
  }
  
  .user-avatar {
    width: 100rpx;
    height: 100rpx;
  }
  
  .user-name {
    font-size: 32rpx;
  }
  
  .section-title {
    font-size: 28rpx;
  }
  
  .service-text {
    font-size: 26rpx;
  }
}

/* 通用样式 */
page {
  margin: 0;
  padding: 0;
  box-sizing: border-box;
}

view, scroll-view, text, image, button {
  box-sizing: border-box;
}

image {
  max-width: 100%;
  height: auto;
  display: block;
}

button {
  margin: 0;
  padding: 0;
  background: none;
  line-height: 1;
}

button::after {
  border: none;
}