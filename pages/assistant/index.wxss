/* 基础容器样式 - 确保页面不左右移动 */
/* 基础容器样式 - 确保页面不左右移动 */
.page {
  box-sizing: border-box;
  width: 100%;
  overflow-x: hidden;
  font-family: -apple-system, BlinkMacSystemFont, 'Helvetica Neue', Helvetica, sans-serif;
  background-color: #f5fbf7;
  margin: 0;
  padding: 0;
  display: flex;
  flex-direction: column;
  align-items: center;
  min-height: 100vh;
}
/* 主容器 - 使用100%宽度，移除最大宽度限制 */
.container {
  background-color: #f5fbf7;
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  padding-bottom: 100rpx;
  width: 100%;
  overflow-x: hidden;
  box-sizing: border-box;
  position: relative;
}

/* 顶部区域 - 调整为固定宽度比例 */
.header {
  background: linear-gradient(135deg, #4a9c7a 0%, #6ba889 100%);
  padding: 30rpx 20rpx 40rpx;
  border-radius: 0 0 30rpx 30rpx;
  box-shadow: 0 4rpx 20rpx rgba(74, 156, 122, 0.3);
  width: 100%;
  max-width: 750rpx;
  margin: 0 auto;
  box-sizing: border-box;
  position: sticky;
  top: 0;
  z-index: 100;
}

/* 主要内容区域 - 修复滚动条问题 */
.main-content {
  flex: 1;
  padding: 20rpx 20rpx 20rpx;
  overflow-y: auto;
  width: 100%;
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
  align-items: center;
  -webkit-overflow-scrolling: touch;
  /* 防止内容被底部导航遮挡 */
  padding-bottom: 120rpx;
}

/* 所有内部容器统一宽度控制 - 使用百分比而不是固定值 */
.section-header,
.input-section,
.output-section,
.features-section,
.quick-options,
.generate-section {
  width: calc(100% - 40rpx);
  margin: 0 auto 30rpx;
  box-sizing: border-box;
}

.logo-section {
  display: flex;
  align-items: center;
  width: 100%;
}

.logo-icon {
  width: 60rpx;
  height: 60rpx;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.title-section {
  display: flex;
  flex-direction: column;
  flex: 1;
  min-width: 0;
}

.app-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #ffffff;
  margin-bottom: 8rpx;
  text-align: left;
  width: 100%;
}

.app-subtitle {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.9);
  text-align: left;
  width: 100%;
}

/* 通用部分样式 - 修复对称性 */
.section-header {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
  text-align: left;
  width: 100%;
  box-sizing: border-box;
}

.section-icon {
  width: 40rpx;
  height: 40rpx;
  flex-shrink: 0;
  margin-right: 15rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #1a6840;
  text-align: left;
  width: 100%;
  box-sizing: border-box;
}

.section-desc {
  font-size: 26rpx;
  color: #6ba889;
  line-height: 1.4;
  margin-bottom: 30rpx;
  text-align: left;
  width: 100%;
  box-sizing: border-box;
}

/* 输入区域 - 修复对称性 */
.input-section {
  background-color: #ffffff;
  border-radius: 20rpx;
  padding: 30rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 4rpx 20rpx rgba(144, 202, 180, 0.1);
  border: 1rpx solid #e0f0e8;
  width: 100%;
  box-sizing: border-box;
}

.input-container {
  margin-bottom: 30rpx;
  width: 100%;
  box-sizing: border-box;
}

.village-input {
  width: 100%;
  height: 200rpx;
  background-color: #f8fcf9;
  border: 2rpx solid #d0e8dc;
  border-radius: 16rpx;
  padding: 20rpx;
  font-size: 28rpx;
  color: #333333;
  line-height: 1.5;
  margin-bottom: 20rpx;
  box-sizing: border-box;
  text-align: left;
  display: block;
  resize: none;
}

.village-input:focus {
  border-color: #5fa8d0;
  outline: none;
}

.placeholder {
  color: #a8c9bb;
  font-size: 28rpx;
  text-align: left;
}

/* 输入底部 - 修复对称性 */
.input-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
  width: 100%;
  box-sizing: border-box;
}

.input-tips {
  display: flex;
  align-items: center;
  flex: 1;
  min-width: 0;
  text-align: left;
}

.tip-icon {
  width: 24rpx;
  height: 24rpx;
  margin-right: 8rpx;
  flex-shrink: 0;
}

.tip-text {
  font-size: 24rpx;
  color: #6ba889;
  text-align: left;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.char-count {
  font-size: 24rpx;
  color: #888888;
  margin-left: 20rpx;
  flex-shrink: 0;
  text-align: right;
  min-width: 60rpx;
}

/* 快速选择 - 修复对称性 */
.quick-options {
  margin-bottom: 30rpx;
  width: 100%;
  text-align: left;
  box-sizing: border-box;
}

.quick-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #1a6840;
  margin-bottom: 20rpx;
  display: block;
  width: 100%;
  text-align: left;
  box-sizing: border-box;
}

.quick-buttons {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
  width: 100%;
  justify-content: flex-start;
  box-sizing: border-box;
}

.quick-btn {
  padding: 12rpx 24rpx;
  background-color: #e8f5ef;
  border: 1rpx solid #b8d9c9;
  border-radius: 40rpx;
  font-size: 24rpx;
  color: #1a6840;
  transition: all 0.3s;
  flex-shrink: 0;
  text-align: center;
  box-sizing: border-box;
  white-space: nowrap;
}

.quick-btn.selected {
  background-color: #4a9c7a;
  border-color: #4a9c7a;
  color: #ffffff;
}

/* 生成按钮 - 修复对称性 */
.generate-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  width: 100%;
  text-align: center;
  box-sizing: border-box;
}

.generate-btn {
  background: linear-gradient(135deg, #4a9c7a 0%, #5fa8d0 100%);
  border: none;
  border-radius: 50rpx;
  padding: 20rpx 50rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 15rpx rgba(74, 156, 122, 0.3);
  transition: all 0.3s;
  width: 100%;
  max-width: 400rpx;
  box-sizing: border-box;
}

.generate-btn:active {
  transform: translateY(2rpx);
  box-shadow: 0 2rpx 8rpx rgba(74, 156, 122, 0.3);
}

.generate-btn[disabled] {
  opacity: 0.6;
}

.btn-icon {
  width: 32rpx;
  height: 32rpx;
  margin-right: 12rpx;
  flex-shrink: 0;
}

.generate-btn text {
  font-size: 28rpx;
  font-weight: 600;
  color: #ffffff;
  white-space: nowrap;
}

.generate-hint {
  font-size: 24rpx;
  color: #6ba889;
  margin-top: 15rpx;
  text-align: center;
  width: 100%;
  box-sizing: border-box;
}

/* 输出区域 - 修复对称性 */
.output-section {
  background-color: #ffffff;
  border-radius: 20rpx;
  padding: 30rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 4rpx 20rpx rgba(144, 202, 180, 0.1);
  border: 1rpx solid #e0f0e8;
  width: 100%;
  box-sizing: border-box;
}

.output-container.empty {
  min-height: 300rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100%;
  box-sizing: border-box;
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 40rpx 0;
  text-align: center;
  width: 100%;
  box-sizing: border-box;
}

.empty-icon {
  width: 120rpx;
  height: 120rpx;
  margin-bottom: 30rpx;
  opacity: 0.6;
  flex-shrink: 0;
}

.empty-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #1a6840;
  margin-bottom: 15rpx;
  text-align: center;
  width: 100%;
  box-sizing: border-box;
}

.empty-desc {
  font-size: 24rpx;
  color: #a8c9bb;
  text-align: center;
  max-width: 400rpx;
  line-height: 1.4;
  box-sizing: border-box;
  width: 100%;
}

/* 攻略内容 - 修复对称性 */
.itinerary-output {
  background-color: #f8fcf9;
  border-radius: 16rpx;
  padding: 30rpx;
  border: 1rpx solid #e0f0e8;
  width: 100%;
  box-sizing: border-box;
}

.itinerary-header {
  margin-bottom: 30rpx;
  padding-bottom: 30rpx;
  border-bottom: 2rpx dashed #d0e8dc;
  width: 100%;
  text-align: left;
  box-sizing: border-box;
}

.itinerary-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #1a6840;
  margin-bottom: 20rpx;
  display: block;
  text-align: left;
  width: 100%;
  box-sizing: border-box;
}

.itinerary-meta {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
  justify-content: flex-start;
  width: 100%;
  box-sizing: border-box;
}

.meta-item {
  display: flex;
  align-items: center;
  background-color: #e8f5ef;
  padding: 8rpx 16rpx;
  border-radius: 20rpx;
  flex-shrink: 0;
  text-align: left;
  box-sizing: border-box;
}

.meta-icon {
  width: 20rpx;
  height: 20rpx;
  margin-right: 8rpx;
  flex-shrink: 0;
}

.meta-text {
  font-size: 22rpx;
  color: #4a9c7a;
  text-align: left;
  white-space: nowrap;
}

/* 每日行程 - 修复对称性 */
.day-sections {
  margin-bottom: 30rpx;
  width: 100%;
  box-sizing: border-box;
}

.day-section {
  margin-bottom: 30rpx;
  background-color: #ffffff;
  border-radius: 12rpx;
  padding: 20rpx;
  border-left: 8rpx solid #4a9c7a;
  width: 100%;
  box-sizing: border-box;
}

.day-header {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
  width: 100%;
  text-align: left;
  box-sizing: border-box;
}

.day-icon {
  width: 24rpx;
  height: 24rpx;
  margin-right: 12rpx;
  flex-shrink: 0;
}

.day-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #1a6840;
  text-align: left;
  width: 100%;
  box-sizing: border-box;
}

.activities {
  margin-left: 10rpx;
  width: 100%;
  box-sizing: border-box;
}

.activity {
  margin-bottom: 20rpx;
  padding-bottom: 20rpx;
  border-bottom: 1rpx dashed #e0f0e8;
  width: 100%;
  box-sizing: border-box;
}

.activity:last-child {
  margin-bottom: 0;
  padding-bottom: 0;
  border-bottom: none;
}

.activity-time {
  display: flex;
  align-items: center;
  margin-bottom: 8rpx;
  width: 100%;
  text-align: left;
  box-sizing: border-box;
}

.time-icon {
  width: 20rpx;
  height: 20rpx;
  margin-right: 8rpx;
  flex-shrink: 0;
}

.activity-time text {
  font-size: 24rpx;
  font-weight: 600;
  color: #5fa8d0;
  text-align: left;
  white-space: nowrap;
}

.activity-desc {
  font-size: 26rpx;
  color: #555555;
  line-height: 1.4;
  margin-left: 28rpx;
  text-align: left;
  width: calc(100% - 28rpx);
  box-sizing: border-box;
}

/* 实用贴士 - 修复对称性 */
.tips-section {
  background-color: #e8f5ef;
  border-radius: 12rpx;
  padding: 20rpx;
  width: 100%;
  box-sizing: border-box;
  text-align: left;
}

.tips-header {
  display: flex;
  align-items: center;
  margin-bottom: 15rpx;
  text-align: left;
  width: 100%;
  box-sizing: border-box;
}

.tips-icon {
  width: 24rpx;
  height: 24rpx;
  margin-right: 12rpx;
  flex-shrink: 0;
}

.tips-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #1a6840;
  text-align: left;
  width: 100%;
  box-sizing: border-box;
}

.tips-list {
  margin-left: 10rpx;
  width: 100%;
  text-align: left;
  box-sizing: border-box;
}

.tip-item {
  display: flex;
  margin-bottom: 10rpx;
  width: 100%;
  text-align: left;
  box-sizing: border-box;
}

.tip-item:last-child {
  margin-bottom: 0;
}

.tip-index {
  font-size: 24rpx;
  color: #4a9c7a;
  font-weight: 600;
  margin-right: 8rpx;
  min-width: 30rpx;
  text-align: left;
  flex-shrink: 0;
}

.tip-content {
  font-size: 24rpx;
  color: #555555;
  line-height: 1.4;
  flex: 1;
  text-align: left;
  width: calc(100% - 38rpx);
  box-sizing: border-box;
}

/* 操作按钮 - 修复对称性 */
.action-buttons {
  display: flex;
  gap: 20rpx;
  margin-top: 30rpx;
  width: 100%;
  justify-content: flex-start;
  box-sizing: border-box;
}

.action-btn {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 16rpx 0;
  border: none;
  border-radius: 10rpx;
  font-size: 24rpx;
  background-color: #ffffff;
  border: 1rpx solid #d0e8dc;
  color: #4a9c7a;
  transition: all 0.3s;
  box-sizing: border-box;
  text-align: center;
  max-width: 200rpx;
  min-width: 120rpx;
}

.action-btn:active {
  transform: translateY(2rpx);
  background-color: #f0f9f5;
}

.action-icon {
  width: 24rpx;
  height: 24rpx;
  margin-right: 8rpx;
  flex-shrink: 0;
}

/* 特色功能 - 修复对称性 */
.features-section {
  background-color: #ffffff;
  border-radius: 20rpx;
  padding: 30rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 4rpx 20rpx rgba(144, 202, 180, 0.1);
  border: 1rpx solid #e0f0e8;
  width: 100%;
  box-sizing: border-box;
}

.features-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 20rpx;
  margin-top: 20rpx;
  width: 100%;
  box-sizing: border-box;
}

.feature-card {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 20rpx;
  background-color: #f8fcf9;
  border-radius: 12rpx;
  border: 1rpx solid #e0f0e8;
  text-align: center;
  width: 100%;
  box-sizing: border-box;
}

.feature-icon-wrapper {
  width: 60rpx;
  height: 60rpx;
  background: linear-gradient(135deg, #4a9c7a 0%, #6ba889 100%);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 15rpx;
  flex-shrink: 0;
}

.feature-icon {
  width: 30rpx;
  height: 30rpx;
  flex-shrink: 0;
}

.feature-title {
  font-size: 24rpx;
  font-weight: 600;
  color: #1a6840;
  margin-bottom: 8rpx;
  text-align: center;
  width: 100%;
  box-sizing: border-box;
}

.feature-desc {
  font-size: 20rpx;
  color: #6ba889;
  line-height: 1.3;
  text-align: center;
  width: 100%;
  box-sizing: border-box;
}

/* 加载遮罩 */
.loading-overlay {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background-color: rgba(255, 255, 255, 0.9);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
  box-sizing: border-box;
}

.loading-content {
  background-color: #ffffff;
  padding: 40rpx;
  border-radius: 20rpx;
  box-shadow: 0 8rpx 30rpx rgba(144, 202, 180, 0.3);
  text-align: center;
  width: 400rpx;
  border: 1rpx solid #e0f0e8;
  box-sizing: border-box;
}

.loading-spinner {
  width: 60rpx;
  height: 60rpx;
  border: 6rpx solid #e0f0e8;
  border-top: 6rpx solid #4a9c7a;
  border-radius: 50%;
  margin: 0 auto 20rpx;
  animation: spin 1s linear infinite;
  box-sizing: border-box;
}

@keyframes spin {
  0% { transform: rotate(0deg); }
  100% { transform: rotate(360deg); }
}

.loading-text {
  font-size: 28rpx;
  font-weight: 600;
  color: #1a6840;
  margin-bottom: 10rpx;
  display: block;
  text-align: center;
  width: 100%;
  box-sizing: border-box;
}

.loading-desc {
  font-size: 24rpx;
  color: #6ba889;
  display: block;
  text-align: center;
  width: 100%;
  box-sizing: border-box;
}

/* 成功提示 */
.toast {
  position: fixed;
  bottom: 100rpx;
  left: 50%;
  transform: translateX(-50%);
  background-color: #4a9c7a;
  padding: 20rpx 30rpx;
  border-radius: 10rpx;
  display: flex;
  align-items: center;
  box-shadow: 0 4rpx 15rpx rgba(74, 156, 122, 0.4);
  z-index: 1001;
  animation: toastSlide 0.3s ease-out;
  box-sizing: border-box;
}

@keyframes toastSlide {
  from {
    opacity: 0;
    transform: translate(-50%, 20rpx);
  }
  to {
    opacity: 1;
    transform: translate(-50%, 0);
  }
}

.toast-icon {
  width: 30rpx;
  height: 30rpx;
  margin-right: 12rpx;
  flex-shrink: 0;
}

.toast-text {
  font-size: 28rpx;
  color: #ffffff;
  font-weight: 600;
  text-align: center;
  white-space: nowrap;
}

/* 通用样式优化 */
page {
  box-sizing: border-box;
}

page {
  width: 100%;
  overflow-x: hidden;
  font-family: -apple-system, BlinkMacSystemFont, 'Helvetica Neue', Helvetica, sans-serif;
  background-color: #f5fbf7;
}

/* 底部导航栏样式 */
.tab-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  width: 100%;
  height: 100rpx;
  background-color: #ffffff;
  display: flex;
  justify-content: space-around;
  align-items: center;
  border-top: 1rpx solid #e0e0e0;
  box-shadow: 0 -2rpx 20rpx rgba(0, 0, 0, 0.05);
  z-index: 100;
  box-sizing: border-box;
}

.tab-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  width: 25%;
  height: 100%;
  transition: all 0.3s;
  box-sizing: border-box;
  padding: 10rpx 0;
}

.tab-item.active {
  background-color: #f8fcf9;
}

.tab-icon {
  width: 44rpx;
  height: 44rpx;
  margin-bottom: 6rpx;
  flex-shrink: 0;
}

.tab-text {
  font-size: 20rpx;
  color: #888;
  text-align: center;
  white-space: nowrap;
}

.tab-item.active .tab-text {
  color: #4a9c7a;
  font-weight: 500;
  text-align: center;
}

/* 响应式调整 */
@media (max-width: 480px) {
  .container {
    padding-bottom: 80rpx;
  }
  
  .main-content {
    padding: 20rpx 20rpx 20rpx;
  }
  
  .header {
    padding: 20rpx 20rpx 30rpx;
  }
  
  .input-section,
  .output-section,
  .features-section {
    padding: 20rpx;
  }
  
  .village-input {
    height: 180rpx;
  }
  
  .quick-buttons {
    gap: 10rpx;
  }
  
  .quick-btn {
    padding: 10rpx 20rpx;
    font-size: 22rpx;
  }
  
  .action-buttons {
    justify-content: space-between;
  }
  
  .action-btn {
    max-width: none;
  }
}