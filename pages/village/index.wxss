/* 全局样式 */
page {
  background-color: #f8fcf9;
  font-family: -apple-system, BlinkMacSystemFont, 'Helvetica Neue', Helvetica, sans-serif;
}

.container {
  padding-bottom: 20rpx;
}

/* 头部样式 */
.header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 30rpx 30rpx 20rpx;
  background-color: #ffffff;
  box-shadow: 0 4rpx 20rpx rgba(144, 202, 180, 0.1);
}

.header-content {
  display: flex;
  flex-direction: column;
}

.header-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #ffffff;
  margin-bottom: 8rpx;
}

.header-subtitle {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.9);
}

.header-actions {
  display: flex;
  gap: 20rpx;
  flex-shrink: 0;
}

.header-icon {
  width: 44rpx;
  height: 44rpx;
  display: block;
}

/* 搜索框 */
.search-box {
  padding: 20rpx 30rpx;
  background-color: #ffffff;
}

.search-input {
  display: flex;
  align-items: center;
  background-color: #f8fcf9;
  border-radius: 20rpx;
  padding: 20rpx 30rpx;
  border: 1rpx solid #d0e8dc;
}

.search-icon {
  width: 20rpx;
  height: 20rpx;
  margin-right: 20rpx;
}

.search-input input {
  flex: 1;
  font-size: 28rpx;
  color: #333;
}

.placeholder {
  color: #a8c9bb;
  font-size: 28rpx;
}

/* 景区列表 */
.recommend-section {
  padding: 0 30rpx 40rpx;
}

.recommend-list {
  display: flex;
  flex-direction: column;
  gap: 30rpx;
  background-color: #ffffff;
  border-radius: 20rpx;
  margin-bottom: 20rpx; /* 减小底部外边距 */
  box-shadow: 0 8rpx 20rpx rgba(144, 202, 180, 0.15); /* 减小阴影强度 */
  width: calc(100% - 40rpx); /* 让卡片宽度收缩，两边留出20rpx边距 */
  margin-left: 20rpx; /* 与搜索框对齐 */
  margin-right: 20rpx; /* 与搜索框对齐 */
  padding: 0; /* 移除内边距，让内容紧贴边框 */
  box-sizing: border-box;
  overflow: hidden; /* 确保圆角裁剪内容 */
}

.recommend-item {
  background-color: #ffffff;
  border-radius: 20rpx;
  overflow: hidden;
  box-shadow: 0 8rpx 30rpx rgba(144, 202, 180, 0.15);
  transition: all 0.3s;
}

.recommend-item:active {
  transform: translateY(-5rpx);
  box-shadow: 0 12rpx 40rpx rgba(144, 202, 180, 0.25);
}

.recommend-img {
  width: 100%;
  height: 300rpx;
}

.recommend-content {
  padding: 25rpx;
}

.recommend-info {
  display: flex;
  flex-direction: column;
}

.recommend-title {
  font-size: 34rpx;
  font-weight: 700;
  color: #1a6840;
  margin-bottom: 15rpx;
}

.recommend-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  margin-bottom: 15rpx;
}

.tag {
  font-size: 22rpx;
  color: #6ba889;
  background-color: #e8f5ef;
  padding: 6rpx 15rpx;
  border-radius: 20rpx;
}

.recommend-desc {
  font-size: 26rpx;
  color: #666;
  line-height: 1.4;
  margin-bottom: 20rpx;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
  text-overflow: ellipsis;
}

.recommend-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.recommend-location {
  display: flex;
  align-items: center;
}

.location-icon {
  width: 24rpx;
  height: 24rpx;
  margin-right: 8rpx;
}

.location-text {
  font-size: 24rpx;
  color: #888;
}

.recommend-distance {
  font-size: 24rpx;
  color: #4a9c7a;
  font-weight: 500;
}

@keyframes toastSlide {
  from {
    opacity: 0;
    transform: translate(-50%, 20rpx);
  }
  to {
    opacity: 1;
    transform: translate(-50%, 0);
  }
}
/* 底部导航栏样式 */
.tab-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  width: 100%;
  height: 100rpx;
  background-color: #ffffff;
  display: flex;
  justify-content: space-around; /* 项均匀分布 */
  align-items: center;
  border-top: 1rpx solid #e0e0e0;
  box-shadow: 0 -2rpx 20rpx rgba(0, 0, 0, 0.05);
  z-index: 100;
  box-sizing: border-box;
}

.tab-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  width: 25%;
  height: 100%;
  transition: all 0.3s;
  box-sizing: border-box;
  padding: 10rpx 0;
}

.tab-item.active {
  background-color: #f8fcf9;
}

.tab-icon {
  width: 44rpx;
  height: 44rpx;
  margin-bottom: 6rpx;
  display: block;
}

.tab-text {
  font-size: 20rpx;
  color: #888;
  text-align: center;
  white-space: nowrap;
}

.tab-item.active .tab-text {
  color: #4a9c7a;
  font-weight: 500;
}

/* 响应式调整 */
@media (max-width: 480px) {
  .scenic-name {
    font-size: 30rpx;
  }
  
  .description-text {
    font-size: 24rpx;
  }
  
  .tag-text {
    font-size: 20rpx;
  }
  
  .location-text, .distance-text {
    font-size: 22rpx;
  }
  
  /* 确保在小屏幕下左右间距对称 */
  .scenic-list {
    padding: 20rpx 20rpx 0;
  }
  
  .search-bar {
    padding: 20rpx 20rpx;
  }
  
  .header {
    padding: 30rpx 20rpx 20rpx;
  }
}

/* 确保所有容器都有正确的盒模型 */
view, scroll-view, text, image, input, button {
  box-sizing: border-box;
}

/* 防止图片超出容器 */
image {
  max-width: 100%;
  height: auto;
  display: block;
}

/* 修复滚动条导致的布局偏移 */
.scenic-list::-webkit-scrollbar {
  width: 0;
  height: 0;
  color: transparent;
}

/* 响应式调整 - 确保小屏幕下对称性依然保持 */
@media (max-width: 480px) {
  .container {
    padding-bottom: 80rpx;
  }
  .main-content {
    flex: 1; /* 填充剩余空间，使内容可延伸至底部 */
    padding: 30rpx 30rpx 20rpx; /* 统一、对称的左右内边距 */
    overflow-y: auto;
    width: 100%;
    box-sizing: border-box;
    display: flex;
    flex-direction: column;
    align-items: stretch; /* 子元素默认拉伸与容器同宽 */
  }
  .header {
    padding: 20rpx 20rpx 30rpx;
  }
  .input-section,
  .output-section,
  .features-section {
    background-color: #ffffff;
    border-radius: 20rpx;
    padding: 30rpx; /* 对称内边距 */
    margin-bottom: 30rpx;
    box-shadow: 0 4rpx 20rpx rgba(144, 202, 180, 0.1);
    border: 1rpx solid #e0f0e8;
    width: 100%;
    box-sizing: border-box;
  }

  .features-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr); /* 两列等宽网格，天然对称 */
    gap: 20rpx; /* 网格间隙 */
    margin-top: 20rpx;
    width: 100%;
    box-sizing: border-box;
  }
  
  .feature-card {
    display: flex;
    flex-direction: column;
    align-items: center; /* 卡片内元素居中 */
    padding: 20rpx; /* 对称内边距 */
    background-color: #f8fcf9;
    border-radius: 12rpx;
    border: 1rpx solid #e0f0e8;
    text-align: center; /* 卡片内文字居中 */
    width: 100%;
    box-sizing: border-box;
  }
  
  .feature-icon-wrapper {
    width: 60rpx;
    height: 60rpx;
    background: linear-gradient(135deg, #4a9c7a 0%, #6ba889 100%);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 15rpx;
    flex-shrink: 0;
  }
  
  .feature-icon {
    width: 30rpx;
    height: 30rpx;
    flex-shrink: 0;
  }
  
  .feature-title {
    font-size: 24rpx;
    font-weight: 600;
    color: #1a6840;
    margin-bottom: 8rpx;
    text-align: center;
    width: 100%;
    box-sizing: border-box;
  }
  
  .feature-desc {
    font-size: 20rpx;
    color: #6ba889;
    line-height: 1.3;
    text-align: center;
    width: 100%;
    box-sizing: border-box;
  }

  .village-input {
    height: 180rpx;
  }
  .quick-buttons {
    gap: 10rpx; /* 小屏幕减少按钮间隙 */
  }
  .quick-btn {
    padding: 10rpx 20rpx;
    font-size: 22rpx;
  }
  .action-buttons {
    justify-content: space-between; /* 小屏幕下按钮撑满空间 */
  }
  .action-btn {
    max-width: none; /* 小屏幕下去掉最大宽度限制 */
  }
}